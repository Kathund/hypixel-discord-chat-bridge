{
  "configVersion": 3,
  "API": {
    "hypixel": {
      "key": "HYPIXEL_API_KEY",
      "baseURL": null
    },
    "mowojang": {
      "baseURL": null
    }
  },
  "bridge": {
    "minecraft": {
      "format": "{username} » {message}"
    },
    "discord": {
      "allowedBots": [
        "BOT_USER_ID"
      ],
      "mode": "bot",
      "format": "{chatType} > {skin} {rank} {username} {guildRank}§f: {message}"
    },
    "channels": {
      "debug": {
        "enabled": true,
        "channel": "DEBUG_CHANNEL_ID"
      },
      "guild": {
        "enabled": true,
        "channel": "GUILD_CHAT_CHANNEL_ID"
      },
      "officer": {
        "enabled": true,
        "channel": "OFFICER_CHANNEL_ID"
      },
      "logging": {
        "enabled": true,
        "channel": "LOGGING_CHANNEL_ID",
        "channels": {
          "guild": null,
          "event": null,
          "error": null,
          "blacklist": null,
          "scripts": null
        }
      }
    },
    "filter": {
      "enabled": true,
      "customWords": [
        "dox",
        "doxx",
        "doxed",
        "doxxed",
        "doxing",
        "doxxing",
        "doxes",
        "doxxes"
      ]
    },
    "stripEmojisFromUsernames": true
  },
  "minecraft": {
    "autoLimbo": true,
    "commands": {
      "messageRepeatBypassLength": 24,
      "maxMessageLength": 256,
      "normal": {
        "enabled": true,
        "prefix": "!"
      },
      "soopy": {
        "enabled": true,
        "prefix": "-"
      }
    },
    "guild": {
      "requirements": {
        "enabled": false,
        "autoAccept": false,
        "requirementsNeededToPass": 1,
        "requirements": {}
      }
    },
    "hypixelAlerts": {
      "hypixelNews": {
        "enabled": true,
        "interval": "5m"
      },
      "statusUpdates": {
        "enabled": true,
        "interval": "5m"
      },
      "skyblockVersion": {
        "enabled": true,
        "interval": "5m"
      },
      "alphaPlayerCountTracker": {
        "enabled": true,
        "interval": "15m",
        "messageCooldown": "1h",
        "playerThreshold": 10
      }
    },
    "bot": {
      "server": "mc.hypixel.net",
      "port": 25565,
      "version": "1.8.9",
      "accountsLocation": "./auth-cache"
    }
  },
  "discord": {
    "serverId": "DISCORD_SERVER_ID",
    "token": "DISCORD_BOT_TOKEN",
    "commands": {
      "checkPermissions": true,
      "staffRole": "COMMAND_ROLE_ID",
      "adminUsers": [
        "486155512568741900",
        "1276524855445164098"
      ]
    }
  },
  "verification": {
    "enabled": false,
    "nickname": {
      "enabled": true,
      "nickname": "{username}",
      "removeCommas": false
    },
    "roles": {
      "verified": {
        "enabled": false,
        "roleId": ""
      },
      "guildMember": {
        "enabled": false,
        "roleId": ""
      },
      "custom": [],
      "autoUpdater": {
        "enabled": false,
        "interval": "24h"
      }
    }
  },
  "blacklist": {
    "enabled": true,
    "notifications": {
      "onBlacklistChange": {
        "enabled": true,
        "shareBlacklister": true
      },
      "onJoinRequest": true,
      "onUserJoinDiscord": true
    },
    "actions": {
      "blockBotAccess": false,
      "kickFromGuild": {
        "enabled": false,
        "reason": "Blacklisted from the guild"
      }
    }
  },
  "statsChannels": {
    "enabled": false,
    "autoUpdater": {
      "enabled": true,
      "interval": "10m"
    },
    "channels": []
  },
  "other": {
    "codeUpdater": {
      "enabled": true,
      "interval": "12h"
    },
    "colors": {
      "Blue": "#3498DB",
      "Red": "#ED4245",
      "Green": "#57F287",
      "Yellow": "#FFD700"
    },
    "backupConfigs": true,
    "logToFiles": true
  }
}
